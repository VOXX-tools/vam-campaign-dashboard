# ============================================
# Google OAuth 2.0 Configuration
# ============================================

# Google OAuth 2.0 Client ID
# 取得方法: Google Cloud Console > 認証情報 > OAuth 2.0 クライアント ID
# 形式: xxxxx-xxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=997500214167-v2jp7tancj9clig85oq1k80a8quumpo8.apps.googleusercontent.com

# ============================================
# Google Spreadsheet Configuration
# ============================================

# Google Spreadsheet ID
# 取得方法: スプレッドシートのURLから抽出
# URL例: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
# 形式: 英数字とハイフンの文字列
VITE_SPREADSHEET_ID=1IwAuWxaQq2joBxNsGyCMnlvLN29ADqconyqXWoSepmA

# Sheet Name (シート名)
# スプレッドシート内の対象シート名を指定
# デフォルト: 進捗率タブ
VITE_SHEET_NAME=進捗率タブ

# ============================================
# Basic Authentication (Vercel Deployment)
# ============================================

# Basic認証のユーザー名
# 推奨: 推測されにくい文字列
# 用途: Vercelデプロイ時のアクセス制限
# 注意: 開発環境では使用されません
BASIC_AUTH_USER=your_username

# Basic認証のパスワード
# 推奨: 強力なパスワード（12文字以上、英数字記号混在）
# 用途: Vercelデプロイ時のアクセス制限
# 注意: 開発環境では使用されません
BASIC_AUTH_PASSWORD=your_password

# ============================================
# 環境変数の設定方法
# ============================================
#
# 【開発環境】
# 1. このファイルをコピーして .env ファイルを作成
#    $ cp .env.example .env
# 2. .env ファイルを編集して実際の値を設定
# 3. 開発サーバーを起動
#    $ npm run dev
#
# 【本番環境（Vercel）】
# 1. Vercelダッシュボードにアクセス
# 2. Settings > Environment Variables を開く
# 3. 上記の環境変数をすべて追加
# 4. デプロイを実行
#
# ============================================
# 必須環境変数
# ============================================
#
# 開発環境:
#   - VITE_GOOGLE_CLIENT_ID (必須)
#   - VITE_SPREADSHEET_ID (必須)
#   - VITE_SHEET_NAME (必須)
#
# 本番環境（Vercel）:
#   - VITE_GOOGLE_CLIENT_ID (必須)
#   - VITE_SPREADSHEET_ID (必須)
#   - VITE_SHEET_NAME (必須)
#   - BASIC_AUTH_USER (必須)
#   - BASIC_AUTH_PASSWORD (必須)
#
# ============================================

